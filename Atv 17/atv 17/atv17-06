   public static void contagemTurma() {
    Scanner entrada = new Scanner(System.in);
    int ttal = 10;
    String[] nome = new String[ttal];
    double[] nota = new double[ttal];
    double soma = 0;
    
    for (int i = 0; i < ttal; i++) {
        System.out.print("Nome do aluno " + (i + 1) + ": ");
        nome[i] = entrada.nextLine(); // Aqui lê o nome normalmente
        
        System.out.print("Nota do(a) " + nome[i] + ": ");
        nota[i] = entrada.nextDouble();
        
        // 🔥 A SOLUÇÃO ESTÁ AQUI:
        entrada.nextLine(); // Esse comando "consome" o Enter que sobrou do nextDouble() e limpa o teclado
        
        soma += nota[i];
    }
    
    double media = soma / ttal;
    System.out.println("\nA media da turma e: " + media);
    
    int maisMedia = 0;
    for (int i = 0; i < ttal; i++) {
        if (nota[i] > media) {
            maisMedia++;
        }
    }
    System.out.print("A quantidade de alunos que ficaram acima da media foi esta: " + maisMedia);
}
